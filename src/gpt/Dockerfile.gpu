# Usa una versión compatible de CUDA (12.x)
FROM nvidia/cuda:12.5.1-devel-ubuntu22.04

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-dev \
    build-essential \
    cmake \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Variables obligatorias para compilar con soporte CUDA
# Ajusta CUDA_ARCHITECTURES según tus GPUs (ej: 86 para RTX 3070/4070, 89 para RTX 4090, 90 para H100)
ENV CMAKE_ARGS="-DGGML_CUDA=on -DCMAKE_CUDA_ARCHITECTURES=86" \
    FORCE_CMAKE=1

# Acelera la compilación usando todos los núcleos
ENV MAKEFLAGS="-j$(nproc)"

RUN pip3 install --no-cache-dir --upgrade pip

# Instala llama-cpp-python desde el código fuente (para que use las opciones de CUDA)
RUN pip3 install --no-cache-dir llama-cpp-python --no-binary llama-cpp-python

WORKDIR /app

COPY requirements.txt load_model.py entrypoint.sh ./

RUN pip3 install --no-cache-dir -r requirements.txt

RUN chmod +x entrypoint.sh

EXPOSE 5000

ENTRYPOINT ["./entrypoint.sh"]